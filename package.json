    ]
  },
  "dependencies": {
    "canvas": "^3.2.1",
    "ink": "^6.8.0",
    "path2d": "^0.3.1",
    "react": "^19.2.4",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "ink": ">=4.0.0",
    "react": ">=18.0.0",
    "uplot": ">=1.6.0"
  }
