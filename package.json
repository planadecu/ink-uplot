{
  "name": "ink-uplot",
  "version": "0.2.4",
  "description": "Render uPlot charts in the terminal with React Ink — truecolor Unicode block art plus native kitty, sixel, and iTerm2 graphics protocols. Line charts, time series, and live dashboards for the CLI.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --external canvas --external uplot --external react --external ink --external path2d --external chafa-wasm && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ink",
    "uplot",
    "cli",
    "chart",
    "charts",
    "terminal",
    "terminal-charts",
    "terminal-graphics",
    "visualization",
    "dataviz",
    "react",
    "typescript",
    "time-series",
    "unicode",
    "truecolor",
    "chafa",
    "sixel",
    "kitty",
    "kitty-graphics-protocol",
    "iterm2",
    "ascii-chart",
    "plot",
    "graph",
    "trading",
    "dashboard",
    "tui",
    "cli-chart",
    "ink-component"
  ],
  "author": {
    "name": "Jordi Planadecursach",
    "url": "https://github.com/planadecu"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/planadecu/ink-uplot.git"
  },
  "bugs": {
    "url": "https://github.com/planadecu/ink-uplot/issues"
  },
  "homepage": "https://github.com/planadecu/ink-uplot#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "tag": "latest",
    "provenance": true
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild"
    ]
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "chafa-wasm": "^0.3.3",
    "path2d": "^0.3.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "ink": "^7.1.0",
    "ink-testing-library": "^4.0.0",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "uplot": "^1.6.32",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "ink": ">=4.0.0",
    "react": ">=18.0.0",
    "uplot": ">=1.6.0"
  }
}
