# Supply-chain hardening (added 2026-05-13).
# pnpm 10 blocks dependency build scripts by default; this allowlist is what permits the
# two deps that legitimately need a native build. Do NOT add `ignore-scripts=true` — it
# also blocks canvas's build, leaving canvas.node missing on fresh installs.
onlyBuiltDependencies[]=canvas
onlyBuiltDependencies[]=esbuild

# Quarantine dependency versions younger than 7 days (in minutes).
minimum-release-age=10080
# Trusted publishers exempt from the release-age quarantine.
minimum-release-age-exclude[]=typescript
minimum-release-age-exclude[]=@typescript/*
